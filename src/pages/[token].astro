const siteOrigin = Astro.url.origin;
const pageUrl = Astro.url.href;

const assetUrl = (path = "") => {
  if (!path) return "";
  try {
    return new URL(path, siteOrigin).toString();
  } catch (_) {
    return path;
  }
};

const faviconUrl = assetUrl(BRAND.favicon);
const appleTouchIconUrl = assetUrl(BRAND.appleTouchIcon);
const ogImageUrl = assetUrl(BRAND.ogImage);
const canonicalUrl = pageUrl;

