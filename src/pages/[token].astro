---
export const prerender = false;

const rawKeyword =
  Astro.url.searchParams.get("n_query") ||
  Astro.url.searchParams.get("keyword") ||
  "";

const normalizeKeyword = (value = "") =>
  String(value)
    .replace(/\+/g, " ")
    .replace(/[<>]/g, "")
    .replace(/["'`{}]/g, "")
    .replace(/\s+/g, "")
    .trim()
    .slice(0, 42);

const keyword = normalizeKeyword(rawKeyword);
const hasKeyword = keyword.length > 0;
const displayKeyword = hasKeyword ? keyword : "금융사기";

const todayLabel = new Intl.DateTimeFormat("ko-KR", {
  timeZone: "Asia/Seoul",
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
})
  .format(new Date())
  .replace(/\.\s*/g, ".")
  .replace(/\.$/, "");

